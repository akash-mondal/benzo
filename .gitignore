# --- secrets (never commit) ---
.env
.env.*
!.env.example

# --- rust / soroban ---
target/
**/*.rs.bk
*.wasm

# --- node / ts ---
node_modules/
dist/
build/
*.tsbuildinfo

# --- zk artifacts (large / generated; regenerate or download) ---
*.zkey
*.ptau
*.wtns
*.r1cs
circuits/**/build/
proofs/

# --- stellar / local state ---
.stellar/
.soroban/

# --- os / editor ---
.DS_Store
*.log
.idea/
.vscode/

# vendored reference material (skills + starter code; present locally, not committed)
reference/
test_snapshots/

# test runner output (regenerated)
test-results/
playwright-report/
deployments/*.bak
audits/
ceremony/

# local facade wallets (contain secrets)
tests/wallets/
apps/web/dist/

# staged prover-enclave artifacts (re-stage from circuits/build)
services/prover-enclave/artifacts/
services/prover-enclave/node_modules/

# --- the build manifest IS needed (fetch-artifacts.sh verifies against it) ---
!circuits/build/artifacts-manifest.json

# --- agent / tooling internal (kept locally, not part of the codebase) ---
.claude/
CLAUDE.md
AGENTS.md
.impeccable.md
.mcp.json
.neon

# --- internal planning / marketing / demo docs (kept locally for context) ---
# README.md is the public source of truth. Local docs, generated decks, screenshots,
# mockups, and design-sweep notes stay off GitHub unless intentionally unignored.
docs/

# --- heavy binary doc artifacts (regenerable, not needed to run/review) ---
*.pptx
*.pdf
.vercel
