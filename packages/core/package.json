    "@phala/dcap-qvl": "^0.5.2",
    "@stellar/stellar-sdk": "^13.0.0",
    "snarkjs": "^0.7.5",
    "@phala/dcap-qvl-web": "^0.3.3"
  },
  "devDependencies": {
    "@benzo/kyc": "workspace:*",
    "@types/node": "^20.14.0",
    "circomlibjs": "^0.1.7",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
