  "description": "Headless TypeScript SDK for the Benzo shielded-USDC protocol on Stellar (notes, Poseidon2, Groth16 proving, viewing keys, contract clients)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
