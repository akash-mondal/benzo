# ──────────────────────────────────────────────────────────────────────────
# OPTIONAL integrations. The hackathon corridor runs with ALL of these BLANK:
# KYC + screening fall back to Mock, on-ramp falls back to Mock, CCTP to Mock,
# and cash in/out uses the self-hosted anchor. Nothing here is required, and
# none of it touches real identities or real money.
# ──────────────────────────────────────────────────────────────────────────

# KYC — MOCK ONLY for the hackathon (no real KYC, no PII collected). DIDIT is an
# OPTIONAL, FUTURE sandbox integration; leave blank to keep the Mock provider.
DIDIT_API_KEY=
KYC_CALLBACK_URL=

# Screening — FUTURE / not active. Blank = Mock. Keys need the provider's account.
RANGE_API_KEY=
HUMAN_ID_CONTRACT=

# Fiat on-ramp — Stripe Crypto, SANDBOX / TEST MODE only. Use a TEST key
# (sk_test_…). Requires a Stripe onramp application + approval first (public
# preview, ~48h) even for sandbox. Blank = Mock.
STRIPE_SECRET_KEY=

# Circle CCTP V2 cross-chain USDC. Testnet/sandbox attestation is key-free, so
# leave blank to use the Mock. Mainnet CCTP is FUTURE.
CIRCLE_API_KEY=

# SEP-24 anchor for cash-out. Only `benzo` (self-hosted) is ACTIVE. moneygram /
# alfred are FUTURE placeholders that need partnerships we do not have.
ANCHOR_PRESET=benzo
