# ──────────────────────────────────────────────────────────────────────────
# Benzo environment — copy to `.env` and fill in, then load with:
#   set -a; . ./.env; set +a
#
# REQUIRED block boots the testnet stack (build, deploy, CLI, relayer, anchor).
# OPTIONAL blocks tune relayer hardening and Mock-by-default integrations —
# leave them blank for the self-hosted testnet/sandbox path (no real identities
# or real money).  .env is gitignored; never commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ===== REQUIRED (testnet) ==================================================

# Network selection + endpoints (these defaults are the public Stellar testnet).
STELLAR_NETWORK=testnet
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# Custodied asset. USE_TEST_TOKEN=false ⇒ the real Circle testnet USDC below
# (the mintable mock-token path is intentionally disabled for deploy).
USE_TEST_TOKEN=false
USDC_CODE=USDC
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Accounts. Create + fund with the Stellar CLI, then paste the keys here, e.g.:
#   stellar keys generate benzo-deployer --network testnet --fund
#   stellar keys address benzo-deployer   # -> DEPLOYER_PUBLIC
#   stellar keys show    benzo-deployer   # -> DEPLOYER_SECRET
# Deployer: deploys the stack and sponsors gasless onboarding (needs testnet XLM
# and a funded USDC trustline to seed deposits).
DEPLOYER_PUBLIC=G...
DEPLOYER_SECRET=S...
# Relayer: submits gasless transfers (pays the XLM fee) and receives the USDC fee.
RELAYER_PUBLIC=G...
RELAYER_SECRET=S...

# Self-hosted SEP-24 anchor accounts (cash-in/out corridor). The distribution
# account holds/settles USDC; the signing account signs SEP-10 challenges.
ANCHOR_DISTRIBUTION_PUBLIC=G...
ANCHOR_DISTRIBUTION_SECRET=S...
ANCHOR_SIGNING_PUBLIC=G...
ANCHOR_SIGNING_SECRET=S...

# ===== OPTIONAL: relayer hardening =========================================
# The relayer is rate-limited even when these are unset. Set RELAYER_AUTH_TOKEN
# to REQUIRE a bearer token. BENZO_ALLOWED_ORIGINS (comma-separated) restricts
# browser CORS to your wallet origin; "*" or empty = open. The relayer only ever
# submits a proven `transfer` that pays its OWN address, so it can never be made
# to subsidize a third party (there is no fee floor — the wallet pays no fee).
RELAYER_AUTH_TOKEN=
BENZO_ALLOWED_ORIGINS=*
# RELAYER_SOURCE=benzo-relayer            # CLI identity the relayer signs with
# RELAYER_MAX_ONBOARDS_PER_DAY=500        # daily sponsored-onboard cap
# RELAYER_TRUST_PROXY=                    # set 1 ONLY behind a trusted reverse proxy (trusts X-Forwarded-For)

# ===== OPTIONAL integrations ===============================================
# The corridor runs with ALL of these BLANK: KYC + screening fall back to Mock,
# on-ramp falls back to Mock, CCTP to Mock, and cash in/out uses the self-hosted
# anchor. Nothing here is required, and none of it touches real identities or
# real money.

# KYC — MOCK ONLY for the hackathon (no real KYC, no PII collected). DIDIT is an
# OPTIONAL, FUTURE sandbox integration; leave blank to keep the Mock provider.
DIDIT_API_KEY=
KYC_CALLBACK_URL=

# Screening — FUTURE / not active. Blank = Mock. Keys need the provider's account.
RANGE_API_KEY=
HUMAN_ID_CONTRACT=

# Fiat on-ramp — Stripe Crypto, SANDBOX / TEST MODE only. Use a TEST key
# (sk_test_…). Requires a Stripe onramp application + approval first (public
# preview, ~48h) even for sandbox. Blank = Mock.
STRIPE_SECRET_KEY=

# Circle CCTP V2 cross-chain USDC. Testnet/sandbox attestation is key-free, so
# leave blank to use the Mock. Mainnet CCTP is FUTURE.
CIRCLE_API_KEY=

# SEP-24 anchor for cash-out. Only `benzo` (self-hosted) is ACTIVE. moneygram /
# alfred are FUTURE placeholders that need partnerships we do not have.
ANCHOR_PRESET=benzo

# ---- Confidential TEE prover (Phala dstack / Intel TDX) — OPTIONAL ----------
# Default proving is on-device (browser WASM) or headless Node — no TEE needed.
# Set these only to route proving through the attested enclave (witness-hiding):
#   BENZO_PROVER_MODE     = local | tee   (default local; tee uses PhalaProver)
#   BENZO_PROVER_ENDPOINT = https URL of the enclave (verifier hits /quote, /prove)
#   BENZO_PROVER_MEASUREMENT = pinned dstack compose-hash the attestation must match
#   BENZO_PROVER_TCB      = accepted TCB status (e.g. UpToDate)
# The deployed reference enclave + measurement are recorded in deployments/testnet.json (tee{}).
BENZO_PROVER_MODE=local
BENZO_PROVER_ENDPOINT=
BENZO_PROVER_MEASUREMENT=
BENZO_PROVER_TCB=

# ---- Local dev escape hatches (NEVER set in any shared/public deployment) ----
# BENZO_DEV_EXPORT=1        exposes GET /api/dev/account (raw spend/view keys -> browser; testnet only)
# BENZO_INSECURE_INDEXER=1  re-enables indexer /scan + /audit (accept viewing secret over HTTP)
# BENZO_KYC_TIER=2          override the testnet KYC tier stand-in (no real IDV behind it)

# zkLogin (Phase 1) — real Google sign-in. Public OAuth Web client id (no secret
# needed for ID-token verification). Blank = demo sign-in for local development.
GOOGLE_CLIENT_ID=
